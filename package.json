{
  "name": "mcp-desktop-automation",
  "version": "0.1.6",
  "description": "Model Context Protocol server for desktop automation",
  "main": "server.js",
  "bin": "./launch.js",
  "files": [
    "LICENSE",
    "README.md",
    "launch.js",
    "launch.sh",
    "launch.cmd",
    "server.js",
    "src/**/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./launch.js",
    "lint": "node ./scripts/run-with-compatible-node.js ./node_modules/eslint/bin/eslint.js .",
    "format": "prettier --write \"*.{js,json,md}\" \".github/workflows/*.{yml,yaml}\" \"docs/**/*.md\" \"test/**/*.js\"",
    "test": "node ./scripts/run-with-compatible-node.js --test test/**/*.test.js",
    "test:unit": "node ./scripts/run-with-compatible-node.js --test test/unit/**/*.test.js",
    "test:contract": "node ./scripts/run-with-compatible-node.js --test test/contract/**/*.test.js",
    "test:smoke": "node ./scripts/run-with-compatible-node.js --test test/smoke/**/*.test.js",
    "test:coverage": "node ./scripts/run-with-compatible-node.js ./scripts/run-coverage.js",
    "test:package": "node ./scripts/run-with-compatible-node.js ./scripts/check-package-contents.js"
  },
  "keywords": [
    "mcp",
    "automation",
    "robot",
    "desktop",
    "screenshot",
    "robotjs"
  ],
  "author": "Adriano Bonat <adrianob@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tanob/mcp-desktop-automation.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "robotjs": "^0.6.0",
    "screenshot-desktop": "^1.15.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3"
  }
}
